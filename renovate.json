{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["gitlab>tnoff-projects/github-workflows//renovate/default"],
  "enabledManagers": ["npm", "cargo", "gitlabci", "custom.regex"],
  "packageRules": [
    {
      "matchPackagePrefixes": ["@sveltejs/"],
      "groupName": "svelte ecosystem"
    },
    {
      "matchPackageNames": ["vite", "typescript"],
      "groupName": "svelte ecosystem"
    },
    {
      "matchPackageNames": ["sha2", "md-5", "hmac", "digest"],
      "groupName": "rust crypto"
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true
    }
  ]
}
